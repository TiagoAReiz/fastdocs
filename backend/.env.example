PROJECT_NAME=FastDocs

# Postgres
POSTGRES_USER=fastdocs
POSTGRES_PASSWORD=fastdocs
POSTGRES_DB=fastdocs
DATABASE_URL=postgresql+asyncpg://fastdocs:fastdocs@postgres:5432/fastdocs

# Redis
REDIS_URL=redis://redis:6379/0

# Azure Blob Storage (Azurite local)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=YOUR_KEY_HERE;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER=documents

# Admin auth (service-to-service)
# Generate SERVICE_API_KEY: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SERVICE_API_KEY=your-service-api-key-here
ADMIN_ALLOWED_IPS=["127.0.0.1","::1"]
ENCRYPTION_KEY=your-fernet-key-here
